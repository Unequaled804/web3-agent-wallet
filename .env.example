# Sepolia RPC endpoint. Suggested providers: Alchemy, Infura, or https://rpc.sepolia.org (public, rate-limited).
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Logical instance id (recommended unique per local agent process).
INSTANCE_ID=default

# Path to the encrypted keystore JSON (generated by `pnpm keystore:create`).
KEYSTORE_PATH=./.wallet/keystore.json

# Password used to decrypt the keystore at runtime.
# For production use, read from a secrets manager instead of a file.
KEYSTORE_PASSWORD=change-me

# Optional wallet registry/store paths (per-instance defaults are auto-derived when empty):
# WALLET_STORE_DIR=./.wallet/wallets-default
# WALLET_REGISTRY_PATH=./.wallet/wallet-registry-default.json
WALLET_STORE_DIR=
WALLET_REGISTRY_PATH=

# SQLite audit database path.
# If set to ./.wallet/wallet.db, server auto-isolates by wallet address:
#   ./.wallet/wallet-<address-prefix>.db
# You can also use {address} placeholder:
#   DB_PATH=./.wallet/{address}.db
# For multi-instance isolation, use both placeholders:
#   DB_PATH=./.wallet/{instance}-{address}.db
DB_PATH=./.wallet/wallet.db

# M2 policy controls (all values in wei):
# - <= POLICY_AUTO_APPROVE_MAX_WEI: auto-approved
# - > POLICY_AUTO_APPROVE_MAX_WEI: pending human approval
# - > POLICY_HARD_MAX_WEI: rejected
POLICY_AUTO_APPROVE_MAX_WEI=10000000000000000
POLICY_HARD_MAX_WEI=200000000000000000

# Optional tx frequency guardrails (count-based). Empty means disabled.
# When exceeded, intents become pending_approval.
POLICY_MAX_TX_PER_MINUTE=
POLICY_MAX_TX_PER_HOUR=

# Optional comma-separated recipient policy lists (EVM addresses).
# Example: POLICY_ALLOWED_TO=0xabc...,0xdef...
POLICY_ALLOWED_TO=
POLICY_BLOCKED_TO=

# Local web console (for human operator interaction).
WEB_CONSOLE_ENABLED=true
WEB_CONSOLE_HOST=127.0.0.1
WEB_CONSOLE_PORT=3939
